{
  "name": "emoti/common-resources",
  "description": "This package contains classes that are used by multiple microservices, as well as things for local communication between them.",
  "type": "library",
  "autoload": {
    "psr-4": {
      "Emoti\\CommonResources\\": "src/"
    }
  },
  "require": {
    "php": "^8.1",
    "ramsey/uuid": "^4.7",
    "php-amqplib/php-amqplib": "^3.7",
    "spatie/laravel-data": "^4.17",
    "ext-sockets": "*",
    "posthog/posthog-php": "^3.7",
    "open-telemetry/api": "^1.8",
    "open-telemetry/exporter-otlp": "^1.4",
    "open-telemetry/sdk": "^1.13",
    "guzzlehttp/guzzle": "^7.8"
  },
  "require-dev": {
    "laravel/framework": "^12.0",
    "dave-liddament/phpstan-php-language-extensions": "^0.9.2"
  },
  "extra": {
    "laravel": {
      "providers": [
        "Emoti\\CommonResources\\CommonResourcesServiceProvider"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "tbachert/spi": true
    }
  }
}
